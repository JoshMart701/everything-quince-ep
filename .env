# Build-time defaults — override these in Vercel project settings with real values.
# NEXT_PUBLIC_* values are safe to commit (exposed to browser anyway).
# Non-NEXT_PUBLIC_ placeholders below allow the build to succeed without real secrets;
# real values must be set in Vercel dashboard before the app functions at runtime.
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder_anon_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
NEXT_PUBLIC_APP_URL=https://everything-quince-ep.vercel.app

# Server-side placeholders (overridden by Vercel dashboard in production)
RESEND_API_KEY=re_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRO_PRICE_ID=price_pro_placeholder
STRIPE_PREMIUM_PRICE_ID=price_premium_placeholder
SUPABASE_SERVICE_ROLE_KEY=placeholder_service_role_key
SEED_SECRET=change_me_before_use

# Standpoint
STRIPE_STANDPOINT_PRICE_ID=price_standpoint_placeholder
ANTHROPIC_API_KEY=sk-ant-placeholder
